// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Invoice {
  id            String     @id
  createdAt     String
  paymentDue    String
  description   String
  paymentTerms  Int
  clientName    String
  clientEmail   String
  status        Status
  senderAddress Json
  clientAddress Json
  total         Float
  items         ItemList[]
}

model ItemList {
  id        String  @id @default(uuid()) @db.Uuid
  name      String
  price     Float
  quantity  Int
  total     Float
  invoiceId String
  Invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

enum Status { 
  paid 
  pending 
  draft 
}
